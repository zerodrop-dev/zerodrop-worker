{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zerodrop-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-05-31",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  }
}